{
  "name": "@amazon-profit/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"console.log('api: lint via TypeScript')\"",
    "test": "node -e \"console.log('api: tests later')\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@amazon-profit/db": "workspace:*",
    "@amazon-profit/types": "workspace:*",
    "@amazon-profit/utils": "workspace:*",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@thallesp/nestjs-better-auth": "^2.7.0",
    "better-auth": "^1.6.23",
    "bullmq": "^5.80.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "csv-parse": "^7.0.1",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  }
}
