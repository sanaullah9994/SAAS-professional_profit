{
  "name": "@amazon-profit/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"console.log('db: lint via TypeScript')\"",
    "test": "node -e \"console.log('db: integration tests later')\"",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": { "dotenv": "^17.4.2", "pg": "^8.22.0" },
  "devDependencies": { "@types/pg": "^8.20.0", "tsx": "^4.23.1", "typescript": "^6.0.3" }
}
