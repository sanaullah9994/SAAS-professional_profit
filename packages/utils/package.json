    "lint": "node -e \"console.log('utils: lint via TypeScript')\"",
    "test": "node -e \"console.log('utils: tests later')\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@amazon-profit/types": "workspace:*",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": { "typescript": "^6.0.3" }
}
